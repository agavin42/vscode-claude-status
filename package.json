{
  "name": "claude-code-status",
  "displayName": "Claude Code Status",
  "description": "Dynamic terminal titles and colors for Claude Code sessions",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.108.0"
  },
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "scm": [
        {
          "id": "claudeTerminals",
          "name": "Claude Sessions",
          "icon": "$(terminal)",
          "contextualTitle": "Claude Code"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "claudeCodeStatus.editSession",
          "when": "view == claudeTerminals",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeStatus.remakeTerminal",
          "when": "view == claudeTerminals",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeStatus.delete",
          "when": "view == claudeTerminals",
          "group": "inline@3"
        },
        {
          "command": "claudeCodeStatus.editSession",
          "when": "view == claudeTerminals",
          "group": "1_edit@1"
        },
        {
          "command": "claudeCodeStatus.remakeTerminal",
          "when": "view == claudeTerminals",
          "group": "1_edit@2"
        },
        {
          "command": "claudeCodeStatus.focusTerminal",
          "when": "view == claudeTerminals && viewItem != terminal-cold",
          "group": "1_edit@3"
        },
        {
          "command": "claudeCodeStatus.newSibling",
          "when": "view == claudeTerminals",
          "group": "2_spawn@1"
        },
        {
          "command": "claudeCodeStatus.fork",
          "when": "view == claudeTerminals",
          "group": "2_spawn@2"
        },
        {
          "command": "claudeCodeStatus.reconnectRemoteControl",
          "when": "view == claudeTerminals && viewItem != terminal-cold && claudeCodeStatus.remoteControlEnabled",
          "group": "2_spawn@3"
        },
        {
          "command": "claudeCodeStatus.suspend",
          "when": "view == claudeTerminals && viewItem != terminal-cold",
          "group": "9_destructive@1"
        },
        {
          "command": "claudeCodeStatus.delete",
          "when": "view == claudeTerminals",
          "group": "9_destructive@2"
        }
      ],
      "view/title": [
        {
          "command": "claudeCodeStatus.newTerminal",
          "when": "view == claudeTerminals",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeCodeStatus.newTerminal",
        "title": "Claude Code: New Terminal",
        "icon": "$(add)"
      },
      {
        "command": "claudeCodeStatus.newTerminalResume",
        "title": "Claude Code: New Terminal (Resume)",
        "icon": "$(history)"
      },
      {
        "command": "claudeCodeStatus.showTerminals",
        "title": "Claude Code: Show Terminals"
      },
      {
        "command": "claudeCodeStatus.focusTerminal",
        "title": "Focus Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "claudeCodeStatus.editSession",
        "title": "Edit Session",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeStatus.renameTerminal",
        "title": "Rename (alias for Edit Session)",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeStatus.remakeTerminal",
        "title": "Remake",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCodeStatus.suspend",
        "title": "Suspend",
        "icon": "$(debug-pause)"
      },
      {
        "command": "claudeCodeStatus.delete",
        "title": "Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "claudeCodeStatus.closeTerminal",
        "title": "Suspend Terminal (alias)"
      },
      {
        "command": "claudeCodeStatus.newSibling",
        "title": "New Sibling (same directory)",
        "icon": "$(repo-clone)"
      },
      {
        "command": "claudeCodeStatus.fork",
        "title": "Fork (resume conversation in a new session)",
        "icon": "$(git-branch)"
      },
      {
        "command": "claudeCodeStatus.reconnectRemoteControl",
        "title": "Reconnect Remote Control",
        "icon": "$(plug)"
      }
    ],
    "keybindings": [
      {
        "command": "claudeCodeStatus.newTerminal",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c"
      }
    ],
    "configuration": {
      "title": "Claude Code Status",
      "properties": {
        "claudeCodeStatus.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable terminal status tracking for Claude Code"
        },
        "claudeCodeStatus.debug": {
          "type": "boolean",
          "default": false,
          "description": "Log debug info to output channel"
        },
        "claudeCodeStatus.permsTimeout": {
          "type": "number",
          "default": 60,
          "minimum": 5,
          "description": "Seconds to wait before auto-clearing PERMS state (when permission dialog is dismissed)"
        },
        "claudeCodeStatus.remoteControl": {
          "type": "boolean",
          "default": false,
          "description": "Launch terminals with --remote-control for Claude Code app connectivity"
        },
        "claudeCodeStatus.command": {
          "type": "string",
          "default": "claude",
          "description": "The command to run in new terminals (e.g. \"claude\", \"claude-code\", \"/path/to/my-wrapper\")"
        },
        "claudeCodeStatus.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments to pass to the claude command (e.g. [\"--model\", \"sonnet\", \"--allowedTools\", \"Bash,Read\"])"
        },
        "claudeCodeStatus.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before deleting a session from the panel. Disable to one-click delete."
        },
        "claudeCodeStatus.ghPath": {
          "type": "string",
          "default": "gh",
          "description": "Path to the GitHub CLI (`gh`) used to refresh PR statuses in the Sessions & PRs dashboard. If `gh` isn't on the extension host's PATH, set an absolute path here."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "tsc -p ./ && node --test \"out/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.108.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  }
}
